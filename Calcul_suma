from flask import Flask, render_template, request

app = Flask(__name__)

@app.route("/", methods=["GET", "POST"])
def home():

    rezultat = []

    if request.method == "POST":

        total_amount = float(request.form["total"])
        num_people = int(request.form["num_people"])

        people = []
        for i in range(num_people):
            people.append(request.form[f"person{i}"])

        pay_equally = request.form["equal"]

        if pay_equally == "yes":

            amount = total_amount / num_people

            for p in people:
                rezultat.append({
                    "name": p,
                    "amount": round(amount,2)
                })

        else:

            individual_amounts = []

            for i in range(num_people):
                individual_amounts.append(float(request.form[f"amount{i}"]))

            remaining = total_amount - sum(individual_amounts)
            shared = remaining / num_people

            for i in range(num_people):
                rezultat.append({
                    "name": people[i],
                    "amount": round(individual_amounts[i] + shared,2)
                })

    return render_template("index.html", rezultat=rezultat)

if __name__ == "__main__":
    app.run(debug=True)